@model Product

@{
    var icons = new Dictionary<string, string> {
        { "Watersports", "🏄" }, { "Soccer", "⚽" }, { "Chess", "♟️" },
        { "Running", "🏃" }, { "Cycling", "🚴" }, { "Fitness", "🏋️" },
        { "Tennis", "🎾" }, { "Basketball", "🏀" }, { "Swimming", "🏊" }
    };
    var colors = new[] { "#dbeafe", "#fce7f3", "#dcfce7", "#fef9c3", "#ede9fe", "#ffedd5" };
    var bg = colors[Math.Abs((Model?.Name ?? "").GetHashCode()) % colors.Length];
    var icon = "🏅";
    foreach (var k in icons.Keys)
    {
        if ((Model?.Category ?? "").Contains(k)) { icon = icons[k]; break; }
    }
}

<div class="product-card">
    <div class="img-area" style="background: @bg;">@icon</div>
    <div class="card-body">
        <div class="product-name">@Model?.Name</div>
        <div class="product-desc">@Model?.Description</div>
        <div class="price-row">
            <span class="price">@Model?.Price.ToString("c")</span>
            <form id="@Model?.ProductID" asp-page="/Cart" method="post" style="margin:0">
                <input type="hidden" asp-for="ProductID" />
                <input type="hidden" name="returnUrl" value="@ViewContext.HttpContext.Request.PathAndQuery()" />
                <button type="submit" class="add-btn">+ Cart</button>
            </form>
        </div>
    </div>
</div>
