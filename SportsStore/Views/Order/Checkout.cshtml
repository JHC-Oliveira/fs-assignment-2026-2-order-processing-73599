@model Order

<style>
    .checkout-wrapper {
        max-width: 560px;
        margin: 0 auto;
    }

    .checkout-header {
        margin-bottom: 24px;
    }

        .checkout-header h4 {
            font-size: 20px;
            font-weight: 800;
            color: #1a1a2e;
            margin: 0;
        }

        .checkout-header p {
            font-size: 13px;
            color: #9ca3af;
            margin: 4px 0 0;
        }

    .checkout-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.08);
        padding: 24px;
        margin-bottom: 16px;
    }

    .section-title {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #9ca3af;
        margin-bottom: 16px;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #f3f4f6;
        }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 12px;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 12px;
    }

        .form-group label {
            font-size: 12px;
            font-weight: 600;
            color: #374151;
        }

        .form-group input[type="text"] {
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            padding: 9px 12px;
            font-size: 14px;
            color: #1a1a2e;
            outline: none;
            transition: border-color 0.2s;
            background: #fafafa;
        }

            .form-group input[type="text"]:focus {
                border-color: #1a1a2e;
                background: #fff;
            }

        .form-group.full {
            grid-column: span 2;
        }

    .giftwrap-row {
        display: flex;
        align-items: center;
        gap: 10px;
        background: #f9fafb;
        border-radius: 8px;
        padding: 12px 14px;
        cursor: pointer;
    }

        .giftwrap-row input {
            width: 16px;
            height: 16px;
            accent-color: #e94560;
            cursor: pointer;
        }

        .giftwrap-row span {
            font-size: 14px;
            font-weight: 600;
            color: #374151;
        }

        .giftwrap-row small {
            font-size: 12px;
            color: #9ca3af;
            display: block;
        }

    .validation-errors {
        background: #fee2e2;
        border-radius: 10px;
        padding: 12px 16px;
        margin-bottom: 16px;
        color: #991b1b;
        font-size: 13px;
    }

    .submit-btn {
        width: 100%;
        background: #e94560;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 14px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.2s;
        letter-spacing: 0.5px;
    }

        .submit-btn:hover {
            background: #c73652;
        }
</style>

<div class="checkout-wrapper">
    <div class="checkout-header">
        <h4>📦 Checkout</h4>
        <p>Fill in your shipping details and we'll get it to you right away</p>
    </div>

    <div asp-validation-summary="All" class="validation-errors"></div>

    <form asp-action="Checkout" method="post">

        <!-- Shipping Info -->
        <div class="checkout-card">
            <div class="section-title">📋 Recipient</div>
            <div class="form-group">
                <label>Full Name</label>
                <input asp-for="Name" type="text" placeholder="John Smith" />
            </div>
        </div>

        <!-- Address -->
        <div class="checkout-card">
            <div class="section-title">📍 Shipping Address</div>
            <div class="form-row">
                <div class="form-group full">
                    <label>Address Line 1</label>
                    <input asp-for="Line1" type="text" placeholder="Street address" />
                </div>
                <div class="form-group full">
                    <label>Address Line 2 <span style="color:#9ca3af;font-weight:400">(optional)</span></label>
                    <input asp-for="Line2" type="text" placeholder="Apartment, suite, etc." />
                </div>
                <div class="form-group full">
                    <label>Address Line 3 <span style="color:#9ca3af;font-weight:400">(optional)</span></label>
                    <input asp-for="Line3" type="text" placeholder="" />
                </div>
                <div class="form-group">
                    <label>City</label>
                    <input asp-for="City" type="text" placeholder="Dublin" />
                </div>
                <div class="form-group">
                    <label>State / County</label>
                    <input asp-for="State" type="text" placeholder="Leinster" />
                </div>
                <div class="form-group">
                    <label>Zip / Eircode</label>
                    <input asp-for="Zip" type="text" placeholder="D01 AB12" />
                </div>
                <div class="form-group">
                    <label>Country</label>
                    <input asp-for="Country" type="text" placeholder="Ireland" />
                </div>
            </div>
        </div>

        <!-- Options -->
        <div class="checkout-card">
            <div class="section-title">🎁 Options</div>
            <label class="giftwrap-row">
                <input asp-for="GiftWrap" type="checkbox" />
                <div>
                    <span>Gift wrap these items</span>
                    <small>We'll wrap your order and include a gift note</small>
                </div>
            </label>
        </div>

        <button type="submit" class="submit-btn">Complete Order →</button>
    </form>
</div>
