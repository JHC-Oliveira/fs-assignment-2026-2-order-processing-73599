<div class="text-center">
    <h2 class="text-danger">Payment Failed</h2>
    <p>Your payment could not be processed. This may be due to:</p>
    <ul class="list-unstyled">
        <li>Insufficient funds</li>
        <li>Card declined by your bank</li>
        <li>Incorrect card details</li>
    </ul>
    <p>No charge has been made to your account.</p>
    <a class="btn btn-primary" asp-action="Checkout">Try Again</a>
    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Return to Store</a>
</div>
