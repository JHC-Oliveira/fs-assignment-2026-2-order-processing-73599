<style>
    .status-wrapper {
        max-width: 440px;
        margin: 60px auto;
        text-align: center;
    }

    .status-icon {
        font-size: 72px;
        margin-bottom: 16px;
    }

    .status-title {
        font-size: 22px;
        font-weight: 800;
        color: #991b1b;
        margin: 0 0 8px;
    }

    .status-msg {
        font-size: 14px;
        color: #9ca3af;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .status-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 1px 8px rgba(0,0,0,0.08);
        padding: 28px;
        margin-bottom: 20px;
    }

    .reasons {
        background: #fef2f2;
        border-radius: 10px;
        padding: 14px 18px;
        margin-bottom: 24px;
        text-align: left;
    }

        .reasons p {
            font-size: 12px;
            font-weight: 700;
            color: #991b1b;
            letter-spacing: 1px;
            text-transform: uppercase;
            margin: 0 0 8px;
        }

        .reasons ul {
            margin: 0;
            padding-left: 18px;
        }

            .reasons ul li {
                font-size: 13px;
                color: #7f1d1d;
                margin-bottom: 4px;
            }

    .no-charge {
        font-size: 12px;
        color: #9ca3af;
        margin-bottom: 20px;
    }

    .btn-danger-custom {
        display: inline-block;
        background: #e94560;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 12px 28px;
        font-size: 14px;
        font-weight: 700;
        text-decoration: none;
        margin: 0 6px;
        transition: background 0.2s;
    }

        .btn-danger-custom:hover {
            background: #c73652;
            color: #fff;
        }

    .btn-ghost {
        display: inline-block;
        background: #f3f4f6;
        color: #374151;
        border: none;
        border-radius: 10px;
        padding: 12px 28px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        margin: 0 6px;
        transition: background 0.2s;
    }

        .btn-ghost:hover {
            background: #e5e7eb;
            color: #1a1a2e;
        }
</style>

<div class="status-wrapper">
    <div class="status-icon">❌</div>
    <div class="status-card">
        <h4 class="status-title">Payment Failed</h4>
        <p class="status-msg">Your payment could not be processed.<br />No charge has been made to your account.</p>
        <div class="reasons">
            <p>Possible reasons</p>
            <ul>
                <li>Insufficient funds</li>
                <li>Card declined by your bank</li>
                <li>Incorrect card details entered</li>
                <li>Expired card</li>
            </ul>
        </div>
        <a asp-action="Checkout" class="btn-danger-custom">🔄 Try Again</a>
        <a asp-controller="Home" asp-action="Index" class="btn-ghost">Return to Store</a>
    </div>
</div>
